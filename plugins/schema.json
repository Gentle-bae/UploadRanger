{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uploadranger.local/plugins/payload-plugin.schema.json",
  "title": "UploadRanger Payload Plugin",
  "description": "社区可扩展的上传测试用例描述（预留，加载器后续实现）",
  "type": "object",
  "required": ["id", "name", "category", "variants"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "name": { "type": "string" },
    "category": {
      "type": "string",
      "enum": [
        "extension_bypass",
        "config_file",
        "polyglot",
        "content_type",
        "filename",
        "other"
      ]
    },
    "target_env": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target_os": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target_lang": {
      "type": "array",
      "items": { "type": "string" }
    },
    "severity": { "type": "string" },
    "description": { "type": "string" },
    "reference": { "type": "string", "format": "uri" },
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["filename", "content_b64"],
        "properties": {
          "filename": { "type": "string" },
          "content_b64": {
            "type": "string",
            "description": "文件内容的 base64，便于 JSON 内嵌二进制"
          },
          "content_type": { "type": "string" },
          "magic_bytes": { "type": "string" }
        }
      }
    }
  }
}
